  "keyFeatures": [
    "Public responsible-person search with live autocomplete",
    "Browse assigned locations by responsible person",
    "View inventory items per location with account numbers",
    "Submit location revision comments from the public interface",
    "Admin panel with JWT-based authentication",
    "Admin search for responsables and ubicaciones",
    "Admin view of full revision history per location",
    "Automatic data import from Excel files (areas.xls and articulos.xls)",
    "MySQL database with SQLAlchemy ORM",
    "React + Vite frontend with Tailwind CSS"
  ],
  "publicApiSurface": [
    "GET /api/responsables/buscar?q={query}",
    "GET /api/ubicaciones/{responsable_id}",
    "GET /api/items/{ubicacion_id}",
    "POST /api/revisiones",
    "POST /api/login",
    "GET /api/admin/responsables/buscar?q={query}",
    "GET /api/admin/ubicaciones/buscar?q={query}",
    "GET /api/admin/responsables/{responsable_id}/ubicaciones",
    "GET /api/admin/items/{ubicacion_id}",
    "GET /api/admin/locations/{id_location}/revisions"
  ]
}
